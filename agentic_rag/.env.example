# ── LLM 提供商配置 ────────────────────────────────────────
# 可选: dashscope | deepseek
LLM_PROVIDER=dashscope
LLM_MODEL_ID=qwen-plus

# DashScope（阿里云百炼）
DASHSCOPE_API_KEY=sk-xxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# DeepSeek（如使用 deepseek 作为 LLM）
DEEPSEEK_API_KEY=sk-xxx

# ── 检索参数 ───────────────────────────────────────────────
RETRIEVAL_TOP_K=5          # 段落检索返回 top-k
KG_TOP_K=5                 # KG 实体检索返回 top-k
KG_CONTEXT_WINDOW=200      # 实体周围取原文字符数（上下文窗口）
MAX_REWRITE_ATTEMPTS=2     # 最大问题改写次数

# ── 路径（如不指定，使用默认相对路径）──────────────────────
# CHROMA_PERSIST_DIR=../rag_pipeline/chroma_db
# LANGEXTRACT_OUTPUT_DIR=../langextract_pipeline/output
# MINERU_OUTPUT_DIR=../mineru_parser/output
