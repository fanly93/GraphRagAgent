# ══════════════════════════════════════════════════════════
# RAG Pipeline 环境配置
# 使用方法：复制此文件为 .env，填写对应字段
# ══════════════════════════════════════════════════════════


# ──────────────────────────────────────────────
# Embedding 模型 [必填]
# ──────────────────────────────────────────────

# 使用哪个 Provider 做 Embedding: dashscope | openai
EMBEDDING_PROVIDER=dashscope

# DashScope Embedding（推荐，与 LangExtract 共用 API Key）
# 模型：text-embedding-v3（1024维，中文优化）
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3

# OpenAI Embedding（备选）
# 模型：text-embedding-3-large（3072维）
# OPENAI_API_KEY=


# ──────────────────────────────────────────────
# LLM（用于 RAG 生成阶段）[必填]
# ──────────────────────────────────────────────

# 与 langextract_pipeline 共用，选择其一
LLM_PROVIDER=dashscope           # dashscope | deepseek
LLM_MODEL_ID=qwen-plus           # qwen-plus / deepseek-chat 等

# API Keys（已在 langextract_pipeline/.env 配置过的直接复制）
# DASHSCOPE_API_KEY 同上（复用）
DEEPSEEK_API_KEY=


# ──────────────────────────────────────────────
# 索引参数 [可选，有默认值]
# ──────────────────────────────────────────────

# 向量库持久化目录（默认：./chroma_db）
# CHROMA_PERSIST_DIR=./chroma_db

# 结构感知切分参数
CHUNK_SIZE=500           # 每个 chunk 目标字符数
CHUNK_OVERLAP=80         # 相邻 chunk 重叠字符数
MIN_CHUNK_SIZE=50        # 小于此值的 chunk 合并到上一个


# ──────────────────────────────────────────────
# 检索参数 [可选，有默认值]
# ──────────────────────────────────────────────

# Hybrid 检索权重（向量 vs BM25，需和为 1.0）
VECTOR_WEIGHT=0.6
BM25_WEIGHT=0.4

# 每路 top-k
RETRIEVAL_TOP_K=4


# ──────────────────────────────────────────────
# 路径 [可选]
# ──────────────────────────────────────────────

# MinerU 输出目录（用于读取 content_list.json）
# MINERU_OUTPUT_DIR=../mineru_parser/output

# LangExtract 输出目录（用于读取实体标注）
# LANGEXTRACT_OUTPUT_DIR=../langextract_pipeline/output
